#!/usr/bin/env bash
# MCP-server wrapper. Resolves repo's tsx + mcp-server.ts regardless of cwd.
# Used by `claude mcp add` so the registration command stays short.

set -e

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "$BIN_DIR/.." && pwd)"

TSX="$REPO_ROOT/node_modules/.bin/tsx"
SERVER="$REPO_ROOT/mcp-server.ts"

[ -x "$TSX" ] || { echo "[designer-mcp] tsx missing at $TSX. Run: npm install --prefix $REPO_ROOT" >&2; exit 1; }
[ -f "$SERVER" ] || { echo "[designer-mcp] mcp-server.ts missing at $SERVER" >&2; exit 1; }

exec "$TSX" "$SERVER" "$@"
